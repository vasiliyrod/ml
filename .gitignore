# =============================================================================
# Data — large files are NOT committed
# =============================================================================
data/raw/*.csv
data/raw/*.json
data/raw/*.parquet
data/raw/*.xlsx
data/raw/*.zip
data/raw/*.tar.gz
data/raw/*.h5
data/raw/*.hdf5
data/processed/*.csv
data/processed/*.json
data/processed/*.parquet
data/processed/*.pkl
data/processed/*.npy
data/processed/*.npz

# Keep directory structure
!data/raw/.gitkeep
!data/processed/.gitkeep

# =============================================================================
# Models — large binary files
# =============================================================================
models/*.pkl
models/*.joblib
models/*.h5
models/*.pt
models/*.pth
models/*.onnx
!models/.gitkeep

# =============================================================================
# Reports — figures are regenerated, but keep CSV
# =============================================================================
reports/figures/*.png
reports/figures/*.jpg
reports/figures/*.svg
reports/figures/*.pdf
!reports/figures/.gitkeep
# ablation_table.csv must be committed — do NOT add it here

